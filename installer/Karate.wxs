<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="Karate"
           Manufacturer="Karate Project"
           Version="0.2.0"
           UpgradeCode="9b1c3a57-6c2e-4d8f-a1b4-2e5f7d9c0a11"
           Language="1033"
           Scope="perMachine"
           Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="A newer version of Karate is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- Add/Remove Programs metadata -->
    <Property Id="ARPCOMMENTS" Value="Karate — Software Update Monitor" />
    <Icon Id="KarateIco" SourceFile="$(var.IconFile)" />
    <Property Id="ARPPRODUCTICON" Value="KarateIco" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Karate" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder" />
    <StandardDirectory Id="DesktopFolder" />

    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Component>
        <File Id="KarateExe" Source="$(var.PublishDir)\Karate.exe" KeyPath="yes" />
      </Component>
      <Component>
        <File Source="$(var.PublishDir)\D3DCompiler_47_cor3.dll" />
      </Component>
      <Component>
        <File Source="$(var.PublishDir)\PenImc_cor3.dll" />
      </Component>
      <Component>
        <File Source="$(var.PublishDir)\PresentationNative_cor3.dll" />
      </Component>
      <Component>
        <File Source="$(var.PublishDir)\vcruntime140_cor3.dll" />
      </Component>
      <Component>
        <File Source="$(var.PublishDir)\wpfgfx_cor3.dll" />
      </Component>
    </ComponentGroup>

    <Component Id="StartMenuShortcut" Directory="ProgramMenuFolder">
      <Shortcut Id="KarateStartMenuShortcut"
                Name="Karate"
                Description="Software Update Monitor"
                Target="[INSTALLFOLDER]Karate.exe"
                WorkingDirectory="INSTALLFOLDER" />
      <RegistryValue Root="HKCU" Key="Software\Karate" Name="StartMenuShortcut" Type="integer" Value="1" KeyPath="yes" />
    </Component>

    <Component Id="DesktopShortcut" Directory="DesktopFolder">
      <Shortcut Id="KarateDesktopShortcut"
                Name="Karate"
                Description="Software Update Monitor"
                Target="[INSTALLFOLDER]Karate.exe"
                WorkingDirectory="INSTALLFOLDER" />
      <RegistryValue Root="HKCU" Key="Software\Karate" Name="DesktopShortcut" Type="integer" Value="1" KeyPath="yes" />
    </Component>

    <Feature Id="Main" Title="Karate" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="StartMenuShortcut" />
      <ComponentRef Id="DesktopShortcut" />
    </Feature>

    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="$(var.LicenseRtf)" />

  </Package>
</Wix>
