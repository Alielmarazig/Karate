<ui:FluentWindow x:Class="Karate.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:Karate.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="Karate"
        Height="780" Width="1220"
        MinHeight="520" MinWidth="820"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Acrylic"
        WindowCornerPreference="Round">

    <ui:FluentWindow.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="RootGrid"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.45" />
                    <DoubleAnimation Storyboard.TargetName="RootSlide"
                                     Storyboard.TargetProperty="Y"
                                     From="16" To="0" Duration="0:0:0.45">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <!-- Slow organic drift of the background orbs -->
                    <DoubleAnimation Storyboard.TargetName="OrbVioletShift" Storyboard.TargetProperty="X"
                                     From="0" To="80" Duration="0:0:16" AutoReverse="True" RepeatBehavior="Forever" />
                    <DoubleAnimation Storyboard.TargetName="OrbVioletShift" Storyboard.TargetProperty="Y"
                                     From="0" To="45" Duration="0:0:21" AutoReverse="True" RepeatBehavior="Forever" />
                    <DoubleAnimation Storyboard.TargetName="OrbAmberShift" Storyboard.TargetProperty="X"
                                     From="0" To="-65" Duration="0:0:14" AutoReverse="True" RepeatBehavior="Forever" />
                    <DoubleAnimation Storyboard.TargetName="OrbAmberShift" Storyboard.TargetProperty="Y"
                                     From="0" To="55" Duration="0:0:18" AutoReverse="True" RepeatBehavior="Forever" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </ui:FluentWindow.Triggers>

    <Grid x:Name="RootGrid">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="RootSlide" />
        </Grid.RenderTransform>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Happy glass: colorful drifting orbs under frosted panels -->
        <Grid Grid.Row="0" Grid.RowSpan="4" IsHitTestVisible="False">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#F2141031" Offset="0" />
                    <GradientStop Color="#F20D1C3B" Offset="0.5" />
                    <GradientStop Color="#F2271534" Offset="1" />
                </LinearGradientBrush>
            </Grid.Background>
            <Ellipse Width="540" Height="540" Fill="#6C63FF" Opacity="0.30"
                     HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-170,-190,0,0">
                <Ellipse.RenderTransform>
                    <TranslateTransform x:Name="OrbVioletShift" />
                </Ellipse.RenderTransform>
                <Ellipse.Effect>
                    <BlurEffect Radius="140" />
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="460" Height="460" Fill="#F7A826" Opacity="0.20"
                     HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-130,-150,0">
                <Ellipse.RenderTransform>
                    <TranslateTransform x:Name="OrbAmberShift" />
                </Ellipse.RenderTransform>
                <Ellipse.Effect>
                    <BlurEffect Radius="130" />
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="580" Height="580" Fill="#2F80ED" Opacity="0.24"
                     HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-190,-230">
                <Ellipse.Effect>
                    <BlurEffect Radius="150" />
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="420" Height="420" Fill="#FF5FA8" Opacity="0.15"
                     HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-130,0,0,-170">
                <Ellipse.Effect>
                    <BlurEffect Radius="130" />
                </Ellipse.Effect>
            </Ellipse>
        </Grid>

        <ui:TitleBar Grid.Row="0" Title="Karate">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/karate.png" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- Menu -->
        <Menu Grid.Row="1" Margin="12,0,12,0" Background="Transparent">
            <MenuItem Header="_File">
                <MenuItem Header="_Scan Applications" Command="{Binding ScanCommand}" />
                <MenuItem Header="_Check for App Updates" Command="{Binding CheckUpdatesCommand}" />
                <Separator />
                <MenuItem Header="Scan _Drivers" Command="{Binding Drivers.ScanCommand}" />
                <MenuItem Header="Check for Driver _Updates" Command="{Binding Drivers.CheckUpdatesCommand}" />
                <Separator />
                <MenuItem Header="_Backup Drivers…" Command="{Binding Drivers.BackupDriversCommand}" />
                <MenuItem Header="_Restore Drivers…" Command="{Binding Drivers.RestoreDriversCommand}" />
                <Separator />
                <MenuItem Header="E_xit" Click="OnExitClick" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Updates _only"
                          IsCheckable="True"
                          IsChecked="{Binding UpdatesOnly}" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="Check for _Updates…" Click="OnCheckSelfUpdateClick" />
                <Separator />
                <MenuItem Header="_About Karate" Click="OnAboutClick" />
            </MenuItem>
        </Menu>

        <!-- Hero banner -->
        <Border Grid.Row="2" Margin="20,8,20,2" CornerRadius="14" Padding="16,12">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#2E6C63FF" Offset="0" />
                    <GradientStop Color="#1A2F80ED" Offset="0.55" />
                    <GradientStop Color="#24F7A826" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Image Grid.Column="0" Source="pack://application:,,,/Assets/karate.png"
                       Width="42" Height="42" VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality">
                    <Image.Effect>
                        <DropShadowEffect Color="#6C63FF" BlurRadius="18" ShadowDepth="0" Opacity="0.6" />
                    </Image.Effect>
                </Image>
                <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                    <TextBlock FontSize="21" FontWeight="ExtraBold" Text="KARATE">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#8B85FF" Offset="0" />
                                <GradientStop Color="#5AA7FF" Offset="0.5" />
                                <GradientStop Color="#F7A826" Offset="1" />
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                    <TextBlock FontSize="12" Text="Software Update Monitor — apps &amp; drivers in one dojo"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Self-update: RED arrow pill when an update is needed -->
                    <ui:Button Appearance="Transparent"
                               Background="#E5484D"
                               Foreground="White"
                               CornerRadius="8"
                               Padding="10,5"
                               Margin="0,0,10,0"
                               Icon="{ui:SymbolIcon ArrowCircleUp24}"
                               Content="{Binding SelfUpdateLabel}"
                               FontWeight="SemiBold"
                               ToolTip="Download and install the new version — Karate restarts itself"
                               Click="OnHeroUpdateClick"
                               Visibility="{Binding SelfUpdateAvailable, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ui:Button.Effect>
                            <DropShadowEffect Color="#E5484D" BlurRadius="18" ShadowDepth="0" Opacity="0.65" />
                        </ui:Button.Effect>
                    </ui:Button>
                    <!-- YELLOW capsule with progress circle while updating -->
                    <Border Margin="0,0,10,0" CornerRadius="8" Padding="10,5"
                            Background="#26F5C518" BorderBrush="#80F5C518" BorderThickness="1"
                            Visibility="{Binding SelfUpdateDownloading, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border.Effect>
                            <DropShadowEffect Color="#F5C518" BlurRadius="16" ShadowDepth="0" Opacity="0.55" />
                        </Border.Effect>
                        <StackPanel Orientation="Horizontal">
                            <ui:ProgressRing Width="20" Height="20"
                                             IsIndeterminate="False"
                                             Foreground="#F5C518"
                                             Progress="{Binding SelfUpdateProgress}" />
                            <TextBlock Text="{Binding SelfUpdateProgress, StringFormat={}Updating… {0:0}%}"
                                       Margin="8,0,0,0" VerticalAlignment="Center"
                                       FontFamily="Cascadia Mono, Consolas" FontSize="12"
                                       Foreground="#F5C518" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border CornerRadius="8" Padding="10,4" VerticalAlignment="Center"
                            Background="#22FFFFFF" BorderBrush="#33FFFFFF" BorderThickness="1">
                        <TextBlock Text="{Binding AppVersion}" FontFamily="Cascadia Mono, Consolas" FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="3" Margin="16,8,16,10" Background="Transparent" BorderThickness="0" Padding="0,10,0,0">
            <TabControl.Resources>
                <Style x:Key="MonoCell" TargetType="TextBlock">
                    <Setter Property="FontFamily" Value="Cascadia Mono, Consolas" />
                    <Setter Property="VerticalAlignment" Value="Center" />
                </Style>
                <!-- Separated pill tabs: light-orange hover, brand gradient when selected -->
                <Style TargetType="TabItem">
                    <Setter Property="Cursor" Value="Hand" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="TabPill"
                                        CornerRadius="10"
                                        Margin="0,0,10,6"
                                        Padding="18,9"
                                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                                        BorderThickness="1"
                                        BorderBrush="Transparent"
                                        RenderTransformOrigin="0.5,0.5">
                                    <Border.RenderTransform>
                                        <ScaleTransform x:Name="PillScale" ScaleX="1" ScaleY="1" />
                                    </Border.RenderTransform>
                                    <ContentPresenter ContentSource="Header"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="TabPill" Property="Background" Value="#33F7A826" />
                                        <Setter TargetName="TabPill" Property="BorderBrush" Value="#80F7A826" />
                                        <Setter TargetName="TabPill" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="#F7A826" BlurRadius="16" ShadowDepth="0" Opacity="0.5" />
                                            </Setter.Value>
                                        </Setter>
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="PillScale"
                                                                     Storyboard.TargetProperty="ScaleX"
                                                                     To="1.05" Duration="0:0:0.12" />
                                                    <DoubleAnimation Storyboard.TargetName="PillScale"
                                                                     Storyboard.TargetProperty="ScaleY"
                                                                     To="1.05" Duration="0:0:0.12" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="PillScale"
                                                                     Storyboard.TargetProperty="ScaleX"
                                                                     To="1" Duration="0:0:0.15" />
                                                    <DoubleAnimation Storyboard.TargetName="PillScale"
                                                                     Storyboard.TargetProperty="ScaleY"
                                                                     To="1" Duration="0:0:0.15" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.ExitActions>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="TabPill" Property="Background">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#6C63FF" Offset="0" />
                                                    <GradientStop Color="#2F80ED" Offset="1" />
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter TargetName="TabPill" Property="BorderBrush" Value="Transparent" />
                                        <Setter TargetName="TabPill" Property="TextElement.Foreground" Value="White" />
                                        <Setter TargetName="TabPill" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="#6C63FF" BlurRadius="20" ShadowDepth="0" Opacity="0.55" />
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- ======================= Applications tab ======================= -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Apps24" Margin="0,0,6,0" />
                        <TextBlock Text="Applications" />
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="8,10,8,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ui:Button Grid.Column="0"
                                   Appearance="Primary"
                                   Icon="{ui:SymbolIcon Search24}"
                                   Content="Scan"
                                   Command="{Binding ScanCommand}"
                                   Margin="0,0,8,0" />

                        <ui:Button Grid.Column="1"
                                   Icon="{ui:SymbolIcon ArrowSync24}"
                                   Content="Check for Updates"
                                   Command="{Binding CheckUpdatesCommand}"
                                   Margin="0,0,8,0" />

                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <ui:Button Icon="{ui:SymbolIcon ArrowDownload24}"
                                       Content="Update All"
                                       Command="{Binding UpdateAllCommand}"
                                       Margin="0,0,16,0" />
                            <CheckBox Content="Updates only"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding UpdatesOnly}" />
                        </StackPanel>

                        <ui:TextBox Grid.Column="4"
                                    Width="300"
                                    Icon="{ui:SymbolIcon Search24}"
                                    PlaceholderText="Search by name or publisher…"
                                    Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>

                    <!-- Counters -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                        <Border CornerRadius="10" Padding="14,10" Margin="0,0,10,0"
                                Background="{DynamicResource ControlFillColorDefaultBrush}">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="38" Height="38" CornerRadius="9" Background="#26F7A826" VerticalAlignment="Center">
                                    <Border.Effect><DropShadowEffect Color="#F7A826" BlurRadius="14" ShadowDepth="0" Opacity="0.45" /></Border.Effect>
                                    <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="19" Foreground="#F7A826"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Margin="12,0,4,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding UpdatesCount}" FontSize="20" FontWeight="Bold" Foreground="#F7A826" />
                                    <TextBlock Text="Updates available" FontSize="12"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="10" Padding="14,10" Margin="0,0,10,0"
                                Background="{DynamicResource ControlFillColorDefaultBrush}">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="38" Height="38" CornerRadius="9" Background="#263FB950" VerticalAlignment="Center">
                                    <Border.Effect><DropShadowEffect Color="#3FB950" BlurRadius="14" ShadowDepth="0" Opacity="0.45" /></Border.Effect>
                                    <ui:SymbolIcon Symbol="CheckmarkCircle24" FontSize="19" Foreground="#3FB950"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Margin="12,0,4,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding UpToDateCount}" FontSize="20" FontWeight="Bold" Foreground="#3FB950" />
                                    <TextBlock Text="Up to date" FontSize="12"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="10" Padding="14,10"
                                Background="{DynamicResource ControlFillColorDefaultBrush}">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="38" Height="38" CornerRadius="9" Background="#266C63FF" VerticalAlignment="Center">
                                    <Border.Effect><DropShadowEffect Color="#6C63FF" BlurRadius="14" ShadowDepth="0" Opacity="0.45" /></Border.Effect>
                                    <ui:SymbolIcon Symbol="Apps24" FontSize="19" Foreground="#8B85FF"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Margin="12,0,4,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding TotalCount}" FontSize="20" FontWeight="Bold" />
                                    <TextBlock Text="Applications" FontSize="12"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Application list -->
                    <Border Grid.Row="2"
                            CornerRadius="8"
                            Background="{DynamicResource ControlFillColorDefaultBrush}">
                        <ui:DataGrid ItemsSource="{Binding AppsView}"
                                     AutoGenerateColumns="False"
                                     IsReadOnly="True"
                                     CanUserAddRows="False"
                                     SelectionMode="Single"
                                     GridLinesVisibility="None"
                                     HeadersVisibility="Column"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Margin="4"
                                     AlternationCount="2">
                            <ui:DataGrid.RowStyle>
                                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="MinHeight" Value="38" />
                                    <Style.Triggers>
                                        <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                            <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#2BF7A826" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:DataGrid.RowStyle>
                            <ui:DataGrid.Columns>
                                <DataGridTextColumn Header="Application" Binding="{Binding Name}" Width="*" />
                                <DataGridTextColumn Header="Current Version" Binding="{Binding Version}" Width="130" ElementStyle="{StaticResource MonoCell}" />
                                <DataGridTextColumn Header="New Version" Binding="{Binding AvailableVersion}" Width="130" ElementStyle="{StaticResource MonoCell}" />
                                <DataGridTextColumn Header="Publisher" Binding="{Binding Publisher}" Width="200" />
                                <DataGridTextColumn Header="Source" Binding="{Binding RegistrySource}" Width="140" />
                                <DataGridTemplateColumn Header="Status" Width="170">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Ellipse Width="8" Height="8"
                                                         Fill="{Binding StatusBrush}"
                                                         Margin="0,0,8,0"
                                                         VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding StatusDisplay}"
                                                           Foreground="{Binding StatusBrush}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ui:Button Content="Update"
                                                       Appearance="Secondary"
                                                       Icon="{ui:SymbolIcon ArrowDownload24}"
                                                       Padding="8,4"
                                                       HorizontalAlignment="Center"
                                                       Visibility="{Binding CanUpdate, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                       Command="{Binding DataContext.UpdateAppCommand, RelativeSource={RelativeSource AncestorType={x:Type ui:DataGrid}}}"
                                                       CommandParameter="{Binding}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </ui:DataGrid.Columns>
                        </ui:DataGrid>
                    </Border>

                    <!-- Status -->
                    <Grid Grid.Row="3" Margin="0,10,0,4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <ProgressBar Grid.Row="0" Height="6" Margin="0,0,0,7"
                                     Maximum="100"
                                     IsIndeterminate="{Binding ProgressIndeterminate}"
                                     Value="{Binding ProgressValue, Mode=OneWay}"
                                     Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding StatusText}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding ProgressDetail}"
                                       Margin="12,0,0,0" VerticalAlignment="Center"
                                       FontFamily="Cascadia Mono, Consolas" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ========================= Drivers tab ========================== -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="DeveloperBoard24" Margin="0,0,6,0" />
                        <TextBlock Text="Drivers" />
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="8,10,8,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ui:Button Grid.Column="0"
                                   Appearance="Primary"
                                   Icon="{ui:SymbolIcon Search24}"
                                   Content="Scan"
                                   Command="{Binding Drivers.ScanCommand}"
                                   Margin="0,0,8,0" />

                        <ui:Button Grid.Column="1"
                                   Icon="{ui:SymbolIcon ArrowSync24}"
                                   Content="Check for Updates"
                                   Command="{Binding Drivers.CheckUpdatesCommand}"
                                   Margin="0,0,8,0" />

                        <ui:Button Grid.Column="2"
                                   Icon="{ui:SymbolIcon Save24}"
                                   Content="Backup"
                                   ToolTip="Export every third-party driver package to a folder (pnputil) — do this before updating anything"
                                   Command="{Binding Drivers.BackupDriversCommand}"
                                   Margin="0,0,8,0" />

                        <ui:Button Grid.Column="3"
                                   Icon="{ui:SymbolIcon ArrowDownload24}"
                                   Content="Restore"
                                   ToolTip="Reinstall driver packages from a Karate backup folder"
                                   Command="{Binding Drivers.RestoreDriversCommand}"
                                   Margin="0,0,8,0" />

                        <ui:Button Grid.Column="4"
                                   Icon="{ui:SymbolIcon Open24}"
                                   ToolTip="Open Windows Update"
                                   Command="{Binding Drivers.OpenWindowsUpdateCommand}"
                                   Margin="0,0,16,0" />

                        <CheckBox Grid.Column="5"
                                  Content="Updates only"
                                  VerticalAlignment="Center"
                                  IsChecked="{Binding Drivers.UpdatesOnly}" />

                        <ui:TextBox Grid.Column="7"
                                    Width="260"
                                    Icon="{ui:SymbolIcon Search24}"
                                    PlaceholderText="Search by device, class or vendor…"
                                    Text="{Binding Drivers.SearchText, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>

                    <!-- Counters -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                        <Border CornerRadius="10" Padding="14,10" Margin="0,0,10,0"
                                Background="{DynamicResource ControlFillColorDefaultBrush}">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="38" Height="38" CornerRadius="9" Background="#26F7A826" VerticalAlignment="Center">
                                    <Border.Effect><DropShadowEffect Color="#F7A826" BlurRadius="14" ShadowDepth="0" Opacity="0.45" /></Border.Effect>
                                    <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="19" Foreground="#F7A826"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Margin="12,0,4,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Drivers.UpdatesCount}" FontSize="20" FontWeight="Bold" Foreground="#F7A826" />
                                    <TextBlock Text="Updates available" FontSize="12"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="10" Padding="14,10"
                                Background="{DynamicResource ControlFillColorDefaultBrush}">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="38" Height="38" CornerRadius="9" Background="#266C63FF" VerticalAlignment="Center">
                                    <Border.Effect><DropShadowEffect Color="#6C63FF" BlurRadius="14" ShadowDepth="0" Opacity="0.45" /></Border.Effect>
                                    <ui:SymbolIcon Symbol="DeveloperBoard24" FontSize="19" Foreground="#8B85FF"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Margin="12,0,4,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Drivers.TotalCount}" FontSize="20" FontWeight="Bold" />
                                    <TextBlock Text="Drivers" FontSize="12"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Driver list -->
                    <Border Grid.Row="2"
                            CornerRadius="8"
                            Background="{DynamicResource ControlFillColorDefaultBrush}">
                        <ui:DataGrid ItemsSource="{Binding Drivers.DriversView}"
                                     AutoGenerateColumns="False"
                                     IsReadOnly="True"
                                     CanUserAddRows="False"
                                     SelectionMode="Single"
                                     GridLinesVisibility="None"
                                     HeadersVisibility="Column"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Margin="4"
                                     AlternationCount="2">
                            <ui:DataGrid.RowStyle>
                                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="MinHeight" Value="38" />
                                    <Style.Triggers>
                                        <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                            <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#2BF7A826" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:DataGrid.RowStyle>
                            <ui:DataGrid.Columns>
                                <DataGridTextColumn Header="Device" Binding="{Binding Name}" Width="*" />
                                <DataGridTextColumn Header="Class" Binding="{Binding DeviceClass}" Width="95" />
                                <DataGridTextColumn Header="Current Version" Binding="{Binding Version}" Width="125" ElementStyle="{StaticResource MonoCell}" />
                                <DataGridTextColumn Header="New Version" Binding="{Binding AvailableVersion}" Width="150" ElementStyle="{StaticResource MonoCell}" />
                                <DataGridTemplateColumn Header="Severity" Width="125">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="7" Padding="10,4"
                                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                                    Background="{Binding SeverityTintBrush}"
                                                    ToolTip="Rating per Microsoft's MSRC severity scale, or Windows Update deployment class (mandatory / automatic / optional) when no MSRC rating exists"
                                                    Visibility="{Binding HasSeverity, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="7" Height="7"
                                                             Fill="{Binding SeverityBrush}"
                                                             Margin="0,0,7,0"
                                                             VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding Severity}"
                                                               Foreground="{Binding SeverityBrush}"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Date" Binding="{Binding DriverDate}" Width="95" ElementStyle="{StaticResource MonoCell}" />
                                <DataGridTextColumn Header="Manufacturer" Binding="{Binding Manufacturer}" Width="140" />
                                <DataGridTemplateColumn Header="Status" Width="170">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Ellipse Width="8" Height="8"
                                                         Fill="{Binding StatusBrush}"
                                                         Margin="0,0,8,0"
                                                         VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding StatusDisplay}"
                                                           Foreground="{Binding StatusBrush}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ui:Button Content="Update"
                                                       Appearance="Secondary"
                                                       Icon="{ui:SymbolIcon ArrowDownload24}"
                                                       Padding="8,4"
                                                       HorizontalAlignment="Center"
                                                       ToolTip="Install via Windows Update (UAC prompt) or open the Catalog download"
                                                       Visibility="{Binding CanUpdate, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                       Command="{Binding DataContext.Drivers.UpdateDriverCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                       CommandParameter="{Binding}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ui:Button Content="Catalog"
                                                       Appearance="Secondary"
                                                       Icon="{ui:SymbolIcon Globe24}"
                                                       Padding="8,4"
                                                       HorizontalAlignment="Center"
                                                       ToolTip="Search the Microsoft Update Catalog for this device"
                                                       Visibility="{Binding HasHardwareId, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                       Command="{Binding DataContext.Drivers.OpenCatalogCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                       CommandParameter="{Binding}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </ui:DataGrid.Columns>
                        </ui:DataGrid>
                    </Border>

                    <!-- Status -->
                    <Grid Grid.Row="3" Margin="0,10,0,4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <ProgressBar Grid.Row="0" Height="6" Margin="0,0,0,7"
                                     Maximum="100"
                                     IsIndeterminate="{Binding Drivers.ProgressIndeterminate}"
                                     Value="{Binding Drivers.ProgressValue, Mode=OneWay}"
                                     Visibility="{Binding Drivers.IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Drivers.StatusText}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Drivers.ProgressDetail}"
                                       Margin="12,0,0,0" VerticalAlignment="Center"
                                       FontFamily="Cascadia Mono, Consolas" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</ui:FluentWindow>
